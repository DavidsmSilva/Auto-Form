{
  "manifest_version": 3,
  "name": "FormAutoFill",
  "version": "1.0",
  "description": "Copia instantáneamente cualquier formulario y pégalo donde quieras",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "FormAutoFill"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
